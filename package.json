    "openclaw": "^2026.3.24",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bovinphang/frontend-craft-openclaw.git"
  }
